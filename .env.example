# Template of required environment variables.
# Copy this file to .env.local and fill with real values from each service's dashboard.
# .env.local is gitignored (see .gitignore) — real secrets stay there.

# Supabase — get these from https://supabase.com/dashboard/project/<your-project>/settings/api
# - URL: your project URL (https://<ref>.supabase.co)
# - PUBLISHABLE_KEY: safe to expose to browsers, equivalent of the old "anon" key (RLS-protected)
# - SECRET_KEY: server-only, bypasses RLS, NEVER expose to clients
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Resend — get the API key from https://resend.com/api-keys
# - RESEND_API_KEY: server-only, allows sending emails from our verified domain
# - RESEND_FROM: sender address. Format: "Display Name <user@verified-subdomain.tld>"
#   Domain must be verified in Resend dashboard first.
RESEND_API_KEY=
RESEND_FROM="Collabbs <hello@send.collabbs.com>"
