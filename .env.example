# Template of required environment variables.
# Copy this file to .env.local and fill with real values from each service's dashboard.
# .env.local is gitignored (see .gitignore) — real secrets stay there.

# Supabase — get these from https://supabase.com/dashboard/project/<your-project>/settings/api
# - URL: your project URL (https://<ref>.supabase.co)
# - PUBLISHABLE_KEY: safe to expose to browsers, equivalent of the old "anon" key (RLS-protected)
# - SECRET_KEY: server-only, bypasses RLS, NEVER expose to clients
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Resend — get the API key from https://resend.com/api-keys
# - RESEND_API_KEY: server-only, allows sending emails from our verified domain
# - RESEND_FROM: sender address. Format: "Display Name <user@verified-subdomain.tld>"
#   Domain must be verified in Resend dashboard first.
RESEND_API_KEY=
RESEND_FROM="Collabbs <hello@send.collabbs.com>"

# Stripe — get these from the Collabbs account dashboard (Developers → API keys), TEST mode for now.
# - PUBLISHABLE_KEY: safe to expose to browsers (pk_test_… / pk_live_…)
# - SECRET_KEY: server-only, NEVER expose to clients (sk_test_… / sk_live_…)
# Connect must be enabled on the account to pay out creators (Connect milestone).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (whsec_…). Set per environment.
# Local dev: from `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# Vercel: register the URL in Stripe Dashboard → Developers → Webhooks, then copy the signing secret.
STRIPE_WEBHOOK_SECRET=

# Cron — generate a long random string (32+ chars). Vercel Cron sends this as
# Authorization: Bearer <CRON_SECRET> when calling /api/cron/* routes.
# Set in Vercel Dashboard → Project Settings → Environment Variables.
CRON_SECRET=
